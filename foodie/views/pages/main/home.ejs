<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FoodieApp | Discover Food Experiences</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <%- include('../../partials/head.ejs') %>

    <style>
        /* HERO */
        .hero {
            height: 65vh;
            background: linear-gradient(rgba(0,0,0,.45), rgba(0,0,0,.45)),
            url("https://images.unsplash.com/photo-1504674900247-0877df9cc836");
            background-size: cover;
            background-position: center;
            color: white;
        }

        .hero h1 {
            font-size: 3rem;
            font-weight: 700;
        }

        /* OPTION CARDS */
        .option-card {
            border-radius: 16px;
            overflow: hidden;
            cursor: pointer;
            transition: transform .2s;
        }

        .option-card:hover {
            transform: scale(1.03);
        }

        .option-card img {
            height: 200px;
            object-fit: cover;
        }

        footer {
            font-size: 14px;
            color: #cbd5e1;
        }

        .nav {
            position: sticky;
            top: 0;
            background-color: #0F172A;
            z-index: 1000;
        }

        .headerText:hover {
            color: rgb(235, 37, 37);
        }

        ::-webkit-scrollbar {
            width: 6px;
        }
        
    </style>
</head>

<body class="bg-dark">

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-dark px-5 nav">
    <a class="navbar-brand fw-bold text-white" href="/">FoodieApp</a>

    <div class="ms-auto d-flex align-items-center gap-3">

        <!-- Dropdown -->
        <div class="dropdown">
            <button class="btn btn-danger dropdown-toggle" data-bs-toggle="dropdown">
                Register
            </button>
            <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="/restaurants/register">Restaurant</a></li>
                <li><a class="dropdown-item" href="/Customer/register">Customer</a></li>
            </ul>
        </div>

        <!-- Login -->
        <div class="dropdown">
            <button class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown">
                Login
            </button>
            <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="/restaurants/login">Restaurant</a></li>
                <li><a class="dropdown-item" href="/Customer/login">Customer</a></li>
            </ul>
        </div>
   </div>
</nav>

<!-- HERO -->
<section class="hero d-flex align-items-center">
    <div class="container text-center">
        <h1>Discover food experiences around you</h1>
        <p class="mt-3 fs-5">
            Explore restaurants, dining, and nightlife near your city
        </p>
    </div>
</section>

<!-- OPTIONS -->
<section class="container mt-5">
    <div class="row g-4">

        <div class="col-md-4">
            <div class="card option-card" onclick="location.href='/order'">
                <img src="https://images.unsplash.com/photo-1600891964599-f61ba0e24092" class="card-img-top" alt="Order Food">
                <div class="card-body">
                    <h5 class="card-title">Order Online</h5>
                    <p class="card-text text-muted">
                        Get your favourite food delivered to your doorstep
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card option-card" onclick="location.href='/dining'">
                <img src="https://images.unsplash.com/photo-1555396273-367ea4eb4db5" class="card-img-top" alt="Dining">
                <div class="card-body">
                    <h5 class="card-title">Dining</h5>
                    <p class="card-text text-muted">
                        Discover the best places to dine out
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card option-card" onclick="location.href='/nightlife'">
                <img src="https://images.unsplash.com/photo-1544148103-0773bf10d330" class="card-img-top" alt="Nightlife">
                <div class="card-body">
                    <h5 class="card-title">Nightlife</h5>
                    <p class="card-text text-muted">
                        Explore nightlife, bars and clubs nearby
                    </p>
                </div>
            </div>
        </div>

    </div>
</section>

<!-- INFO -->
<section class="container mt-5 text-center">
    <p class="text-white">
        FoodieApp helps you discover great food experiences around you.
    </p>
</section>

<!-- FOOTER -->
<footer class="text-center text-white mt-5 mb-4">
    © 2025 FoodieApp
</footer>

<!-- Bootstrap JS (IMPORTANT for dropdown) -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>