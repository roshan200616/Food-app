<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Food Menu</title>

    <!-- Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/customerHome.css"
    <style>
        
    </style>
</head>
<body>
    <div class="container-fluid">
    <div class="row">

        <!-- Sidebar -->
        <div class="col-2 p-0">
            <%- include('../../partials/customerSidebar.ejs')%>
        </div>

        <!-- Main Content -->
        <div class="col-10">
            <div class="container mt-4">
                <div class="row g-4">

                    <% data.forEach(item=> { %>
                        <div class="col-md-3 d-flex">
                            <div class="card food-card w-100">
                                <img src="/food_image/images.jpg" class="food-img">
                                <div class="card-body">
                                    <div>
                                        <h5><%= item.food_item %></h5>
                                        <p>Meal Type: <%= item.meal_type %></p>
                                        <h6>Price: ₹<%= item.price %></h6>
                                    </div>

                                    <button class="btn btn-success w-100 btn-order"
                                        onclick="addToCart('<%= item.food_item %>')">
                                        Add to Cart
                                    </button>
                                </div>
                            </div>
                        </div>
                    <% }) %>

                </div>
            </div>
        </div>

    </div>
</div>
</body>

<script>
    let cart = []
    function showToast(message) {
        const toastEl = document.getElementById('myToast');
        const toastMsg = document.getElementById('toastMsg');

        toastMsg.innerText = message;

        const toast = new bootstrap.Toast(toastEl, {
            delay: 2000   // auto hide after 2 sec
        });

        toast.show();
    }
    function addToCart(food) {
        cart.push(food)
        showToast("Successfully add to cart")

    }
    function viewCart() {
        console.log(cart)
    }


</script>

</html>