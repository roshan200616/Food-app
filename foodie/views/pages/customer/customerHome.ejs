<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Food Menu</title>

    <!-- Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #0f172a;
            font-family: 'Segoe UI', sans-serif;
        }

        /* Profile Sidebar */
        .profile-sidebar {
            background-color: #020617;
            min-height: 100vh;
            color: white;
            padding: 20px;
        }

        .profile-card {
            background-color: #1e293b;
            border-radius: 15px;
            padding: 20px;
            text-align: center;
        }

        .profile-img {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            object-fit: cover;
            margin-bottom: 10px;
        }

        /* Main Content */
        .main-content {
            background-color: #020617;
            min-height: 100vh;
            color: white;
        }

        /* Food Card */
        .food-card {
            background-color: #1e293b;
            border-radius: 15px;
            transition: 0.3s;
            color: white;
        }

        .food-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4);
        }

        .food-img {
            height: 180px;
            object-fit: cover;
            border-top-left-radius: 15px;
            border-top-right-radius: 15px;
        }

        .badge {
            background-color: #334155;
        }

        /* Cart */
        .cart {
            position: fixed;
            top: 20px;
            right: 30px;
            display: flex;
            justify-content: flex-end;
        }

        .cart a {
            background: #22c55e;
            padding: 10px 18px;
            border-radius: 10px;
            color: white;
            font-weight: bold;
            text-decoration: none;
        }

        /* Toast */
        .toast {
            background-color: #1e293b;
            color: white;
        }
    </style>
</head>

<body>
    <div class="container-fluid">
        <div class="row">

            <!-- PROFILE SIDEBAR -->
            <div class="col-3 profile-sidebar">

                <div class="profile-card">
                    <!-- <img src="https://via.placeholder.com/80" class="profile-img"> -->

                    <h5>
                        <%= cusData.name%>
                    </h5>
                    <p class="text-secondary">mobile:<%= cusData.mobile%>
                    </p>
                    <p class="text-secondary">Email:<%= cusData.email%>
                    </p>

                    <a href="/logout" class="btn btn-danger btn-sm mt-2 w-100">
                        Logout
                    </a>
                </div>

            </div>

            <!-- MAIN CONTENT -->
            <div class="col-9 main-content">
                <div class="container mt-4">

                    <h3 class="mb-4 fw-bold">🍽️ Food Menu</h3>

                    <div class="row g-4">
                        <%data.forEach(item=> { %>
                            <div class="col-md-4 d-flex">
                                <div class="card food-card w-100">

                                    <img src="/food_image/images.jpg" class="food-img">

                                    <div class="card-body d-flex flex-column justify-content-between">

                                        <div>
                                            <h5>
                                                <%= item.food_name %>
                                            </h5>

                                            <span class="badge mb-2">
                                                Sugar:<%= item.sugar %>
                                            </span>
                                            <span class="badge mb-2">
                                                Fat:<%= item.fat %>
                                            </span>
                                            <span class="badge mb-2">
                                                protein:<%= item.protein %>
                                            </span>
                                            <span class="badge mb-2">
                                                carbs:<%= item.carbs %>
                                            </span>
                                            <span class="badge mb-2">
                                               calories:<%= item.calories %>
                                            </span>



                                            <h6>₹<%= item.price %>
                                            </h6>
                                        </div>

                                        <button class="btn btn-success mt-3" onclick="addToCart('<%= item.menu_id %>')">
                                            Add to Cart
                                        </button>

                                    </div>
                                </div>
                            </div>
                            <% }) %>

                    </div>
                </div>
            </div>

            <!-- CART -->
            <div class="cart">
                <a href="/customer/cart">
                    🛒 Cart (<span id="cartCount">0</span>)
                </a>
            </div>

            <!-- TOAST -->
            <div class="toast position-fixed bottom-0 end-0 p-3" id="myToast">
                <div class="toast-body" id="toastMsg"></div>
            </div>

        </div>
    </div>

</body>


<script>
    const foods = <%- JSON.stringify(data) %>
        function showToast(message) {
            const toastEl = document.getElementById('myToast');
            const toastMsg = document.getElementById('toastMsg');

            toastMsg.innerText = message;

            const toast = new bootstrap.Toast(toastEl, { delay: 2000 });
            toast.show();
        }

    function addToCart(id) {
        const item = foods.find(food => food.menu_id == id);
        const myHeaders = new Headers();
        myHeaders.append("Content-Type", "application/json");
        myHeaders.append("Cookie", "connect.sid=s%3AYs9pwpGlTQiUqMjk6SBfZpFSBLrO12eh.VZIqrNLMyc0KEwVbX8ftvwf6yo3vYL633%2Fy6xDQlDsM");
        const raw = JSON.stringify(item);

        const requestOptions = {
            method: "POST",
            headers: myHeaders,
            body: raw,
            redirect: "follow"
        };
        try {
            fetch("http://localhost:3000/api/customer/cart", requestOptions)
                .then(async (response) => {
                    if (response.status === 200) {
                        const data = await response.json()
                        document.getElementById("cartCount").innerText = data.length
                    }
                    else {
                        const error = await response.text()
                        console.log(error)
                    }
                })
        }
        catch (err) {
            console.log(err)
        }
    }

</script>

</html>